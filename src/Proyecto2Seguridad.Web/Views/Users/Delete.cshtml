@model Proyecto2Seguridad.Web.ViewModels.UserFormViewModel

@{
    ViewData["Title"] = "Eliminar usuario";
}

<h1 class="mb-4">Eliminar usuario</h1>

<div class="alert alert-warning">
    <h4>¿Seguro que deseas eliminar este usuario?</h4>
</div>

<div class="mb-3">
    <dl class="row">
        <dt class="col-sm-3">Nombre de usuario</dt>
        <dd class="col-sm-9">@Model.UserName</dd>

        <dt class="col-sm-3">Correo</dt>
        <dd class="col-sm-9">@Model.Email</dd>

        <dt class="col-sm-3">Rol</dt>
        <dd class="col-sm-9">@Model.Role</dd>

        <dt class="col-sm-3">Último login</dt>
        <dd class="col-sm-9">
            @if (Model.LastLoginAt.HasValue)
            {
                @Model.LastLoginAt.Value.ToLocalTime().ToString("dd/MM/yyyy HH:mm:ss")
            }
            else
            {
                <span>No registrado</span>
            }
        </dd>
    </dl>
</div>

<form asp-action="Delete" method="post">
    @Html.AntiForgeryToken()
    <input type="hidden" asp-for="Id" />
    <button type="submit" class="btn btn-danger">Eliminar</button>
    <a asp-action="Index" class="btn btn-secondary">Cancelar</a>
</form>