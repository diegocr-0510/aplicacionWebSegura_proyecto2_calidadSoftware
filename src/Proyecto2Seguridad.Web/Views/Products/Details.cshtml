@model Proyecto2Seguridad.Web.Models.Product

@{
    ViewData["Title"] = "Detalle del producto";
}

<h1 class="mb-4">Detalle del producto</h1>

<div>
    <dl class="row">
        <dt class="col-sm-2">Código</dt>
        <dd class="col-sm-10">@Model.Code</dd>

        <dt class="col-sm-2">Nombre</dt>
        <dd class="col-sm-10">@Model.Name</dd>

        <dt class="col-sm-2">Descripción</dt>
        <dd class="col-sm-10">@Model.Description</dd>

        <dt class="col-sm-2">Cantidad</dt>
        <dd class="col-sm-10">@Model.Quantity</dd>

        <dt class="col-sm-2">Precio</dt>
        <dd class="col-sm-10">@Model.Price.ToString("C")</dd>

        <dt class="col-sm-2">Creado</dt>
        <dd class="col-sm-10">@Model.CreatedAt.ToLocalTime()</dd>

        <dt class="col-sm-2">Actualizado</dt>
        <dd class="col-sm-10">@Model.UpdatedAt.ToLocalTime()</dd>
    </dl>
</div>

<div>
    @if (User.IsInRole("SuperAdmin") || User.IsInRole("Registrador"))
    {
        <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-warning">Editar</a>
    }

    <a asp-action="Index" class="btn btn-secondary">Volver</a>
</div>