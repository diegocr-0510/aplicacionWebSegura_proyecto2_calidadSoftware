@model IEnumerable<Proyecto2Seguridad.Web.Models.Product>

@{
    ViewData["Title"] = "Productos";
}

<h1 class="mb-4">Productos</h1>

@if (User.IsInRole("SuperAdmin") || User.IsInRole("Registrador"))
{
    <p>
        <a asp-action="Create" class="btn btn-primary">Crear producto</a>
    </p>
}

<table class="table table-bordered table-striped">
    <thead>
        <tr>
            <th>Código</th>
            <th>Nombre</th>
            <th>Descripción</th>
            <th>Cantidad</th>
            <th>Precio</th>
            <th>Creado</th>
            <th>Actualizado</th>
            <th>Acciones</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var item in Model)
        {
            <tr>
                <td>@item.Code</td>
                <td>@item.Name</td>
                <td>@item.Description</td>
                <td>@item.Quantity</td>
                <td>₡@item.Price.ToString("N2")</td>
                <td>@item.CreatedAt.ToLocalTime()</td>
                <td>@item.UpdatedAt.ToLocalTime()</td>
                <td>
                    <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-info btn-sm">Detalle</a>

                    @if (User.IsInRole("SuperAdmin") || User.IsInRole("Registrador"))
                    {
                        <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-warning btn-sm">Editar</a>
                        <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-danger btn-sm">Eliminar</a>
                    }
                </td>
            </tr>
        }
    </tbody>
</table>